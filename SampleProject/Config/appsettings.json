{
  "Environment": {
    "Current": "QA",
    "Environments": {
      "QA": {
        "WebUrl": "https://testautomationpractice.blogspot.com/",
        "ApiUrl": "https://jsonplaceholder.typicode.com",
        "Timeout": 30
      },
      "UAT": {
        "WebUrl": "https://uat.testautomationpractice.blogspot.com/",
        "ApiUrl": "https://jsonplaceholder.typicode.com",
        "Timeout": 30
      },
      "Production": {
        "WebUrl": "https://testautomationpractice.blogspot.com/",
        "ApiUrl": "https://jsonplaceholder.typicode.com",
        "Timeout": 30
      }
    }
  },
  "Browser": {
    "BrowserType": "Chrome",
    "Headless": false,
    "WindowSize": "1920,1080",
    "ImplicitWait": 10,
    "ExplicitWait": 20,
    "ScreenshotOnFailure": true,
    "ScreenshotPath": "./Screenshots/"
  },
  "Browser.Chrome": {
    "BinaryPath": null,
    "Arguments": [
      "--start-maximized",
      "--disable-blink-features=AutomationControlled",
      "--disable-dev-shm-usage"
    ]
  },
  "Browser.Edge": {
    "BinaryPath": null,
    "Arguments": [
      "--start-maximized",
      "--disable-blink-features=AutomationControlled"
    ]
  },
  "Browser.Firefox": {
    "BinaryPath": null,
    "Arguments": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
